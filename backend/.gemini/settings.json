{
  "context": {
    "fileName": ["AGENTS.md", "GEMINI.md"]
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "check-anti-patterns",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.claude/hooks/check-anti-patterns.sh",
            "timeout": 5000
          },
          {
            "name": "check-generated-code",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.claude/hooks/check-generated-code.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "format-go",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.claude/hooks/format-go.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
