# ============================================
# Production .env — 存放於 VPS ~/blog/.env
# docker-compose.yml 讀取此檔案
# ============================================

# PostgreSQL
POSTGRES_PASSWORD=<random-32-char>

# JWT
JWT_SECRET=<random-base64>

# Cloudflare R2 (S3-compatible object storage)
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=blog
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# GitHub (Obsidian content sync)
GITHUB_WEBHOOK_SECRET=<webhook-secret>
GITHUB_TOKEN=<github-pat>
GITHUB_REPO=Koopa0/obsidian

# AI (required unless MOCK_MODE=true)
GEMINI_API_KEY=<gemini-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>

# Notion (optional)
NOTION_API_KEY=<notion-api-key>
NOTION_WEBHOOK_SECRET=<notion-webhook-secret>
NOTION_PROJECTS_DB=<notion-database-id>
NOTION_TASKS_DB=<notion-database-id>
NOTION_BOOKS_DB=<notion-database-id>

# Notifications (optional — empty = noop)
LINE_CHANNEL_TOKEN=<line-channel-access-token>
LINE_USER_ID=<line-user-id>
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_CHAT_ID=<telegram-chat-id>
