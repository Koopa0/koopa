; angular-eslint 21.4.x peer-requires @angular/cli "<22", but the project is on
; Angular 22. No stable angular-eslint v22 exists yet (only 21.4.x + alphas), and
; 21.4 lints Angular 22 correctly. legacy-peer-deps lets `npm ci` resolve the
; lockfile without the (cosmetic) ERESOLVE. Revisit once angular-eslint v22 ships.
legacy-peer-deps=true
